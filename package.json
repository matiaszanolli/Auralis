{
  "name": "auralis",
  "version": "1.5.0",
  "description": "Auralis Audio Mastering Suite",
  "main": "desktop/main.js",
  "scripts": {
    "dev": "node dev.js",
    "build": "node build.js",
    "package": "node package.js",
    "package:win": "node package.js win",
    "package:mac": "node package.js mac",
    "package:linux": "node package.js linux",
    "test": "python -m pytest tests/",
    "test:coverage": "python -m pytest tests/ --cov=auralis --cov-report=html",
    "install:all": "npm run install:desktop && npm run install:frontend",
    "install:desktop": "cd desktop && npm install",
    "install:frontend": "cd auralis-web/frontend && npm install",
    "clean": "rm -rf dist/ desktop/node_modules/ auralis-web/frontend/node_modules/ auralis-web/frontend/dist/ backend/dist/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/matiaszanolli/Auralis.git"
  },
  "keywords": [
    "audio",
    "mastering",
    "music",
    "electron",
    "python",
    "react"
  ],
  "author": "Auralis Team",
  "license": "AGPL-3.0",
  "bugs": {
    "url": "https://github.com/matiaszanolli/Auralis/issues"
  },
  "homepage": "https://github.com/matiaszanolli/Auralis#readme",
  "engines": {
    "node": ">=24.0.0",
    "python": ">=3.14.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}